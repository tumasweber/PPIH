{
  "routes": [
    {
      "route": "/",
      "rewrite": "/default.html"
    },
    {
      "route": "/default.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    },
    {
      "route": "/data.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/default.html"
  },
  "mimeTypes": {
    ".js": "application/javascript"
  }
}
